{
  "name": "ishguard-security-suite",
  "version": "3.0.0",
  "private": true,
  "description": "ISHGuard v3 Enterprise AI Cybersecurity Platform – AI-powered, offline-first device protection for Windows, Web & Android",
  "scripts": {
    "dev": "cd website && npm run dev",
    "build": "npm run build:engine && npm run build:website",
    "build:all": "npm run build:engine && npm run build:website && npm run build:desktop && npm run build:mobile",
    "build:website": "cd website && npm run build",
    "build:desktop": "cd desktop && npm run build",
    "build:desktop:dir": "cd desktop && npm run pack",
    "build:engine": "cd engine && node test.js",
    "build:mobile": "node scripts/build-mobile.js",
    "dist": "npm run build:all && npm run dist:copy-installers",
    "dist:copy-installers": "node scripts/copy-installers.js",
    "serve": "cd website && npx vite preview --port 3000",
    "start": "cd desktop && npm run dev",
    "version": "node scripts/bump-version.js"
  },
  "keywords": [
    "cybersecurity", "ai-security", "enterprise-security", "antivirus",
    "ransomware-protection", "behavioral-analysis", "endpoint-protection",
    "device-protection", "security-monitor", "ishguard", "offline-security",
    "windows-security", "android-security", "network-security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ishconnlab/ishguard"
  }
}
